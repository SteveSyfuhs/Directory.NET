FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Install Node.js for SPA build
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Copy Directory.build.props (defines TargetFramework) and project files, then restore
COPY Directory.build.props ./
COPY src/Directory.Core/*.csproj src/Directory.Core/
COPY src/Directory.Schema/*.csproj src/Directory.Schema/
COPY src/Directory.Security/*.csproj src/Directory.Security/
COPY src/Directory.CosmosDb/*.csproj src/Directory.CosmosDb/
COPY src/Directory.Ldap/*.csproj src/Directory.Ldap/
COPY src/Directory.Rpc/*.csproj src/Directory.Rpc/
COPY src/Directory.Replication/*.csproj src/Directory.Replication/
COPY src/Directory.Dns/*.csproj src/Directory.Dns/
COPY src/Directory.Kerberos/*.csproj src/Directory.Kerberos/
COPY src/Directory.Web/*.csproj src/Directory.Web/
RUN dotnet restore src/Directory.Web/Directory.Web.csproj

# Copy source and build
COPY src/ src/
RUN dotnet publish src/Directory.Web/Directory.Web.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app .
EXPOSE 6001
ENTRYPOINT ["dotnet", "Directory.Web.dll"]
